CREATE PROCEDURE atletas_e_clubes()
BEGIN
    SELECT 
        C.nome_clube AS Equipe,
        COUNT(DISTINCT A.id_atleta) AS Total_Atletas_Inscritos,
        COUNT(R.id_resultado) AS Total_Provas_Disputadas,
        SUM(R.pontos) AS Pontuacao_Total_Acumulada,
        ROUND(AVG(R.pontos), 2) AS Media_Eficiencia_por_Prova
    FROM CLUBE C
    LEFT JOIN ATLETA A ON C.id_clube = A.id_clube
    LEFT JOIN RESULTADO R ON A.id_atleta = R.id_atleta
    GROUP BY C.id_clube, C.nome_clube
    ORDER BY Pontuacao_Total_Acumulada DESC;
END;
